<Page x:Class="Pr4_523_Glushkov_Sidorov.Pages.Problem1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr4_523_Glushkov_Sidorov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Problem1"
      Background="CadetBlue">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.75*"/>
        </Grid.RowDefinitions>
        <Image Source="/Images/Problem1.jpg" Margin="15"/>
        <Grid Grid.Row="1" Width="400" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Label FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Content="X"/>
            <TextBox Height="30" Width="120" Grid.Column="1"/>
            <Label FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Content="Y"/>
            <TextBox Height="30" Width="120" Grid.Column="1" Grid.Row="1"/>
            <Label FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2" Content="Z"/>
            <TextBox Height="30" Width="120" Grid.Column="1" Grid.Row="2"/>
            <Label FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="3" Content="Ответ:"/>
            <TextBox Height="30" Width="120" Grid.Column="1" Grid.Row="3"/>
            <Button x:Name="CalculateBtn1" Height="40" Width="100" FontSize="18"  HorizontalAlignment="Center" Grid.Column="2" Content="Вычислить" />
            <Button x:Name="ClearBtn1" Height="40" Width="100" FontSize="18"  HorizontalAlignment="Center" Grid.Column="2" Grid.Row="2" Content="Очистить"/>
            <Button x:Name="BackBtn1" Height="40" Width="100" FontSize="18"  HorizontalAlignment="Center" Grid.Column="2" Grid.Row="3" Content="Назад" Click="BackBtn1_Click"/>
        </Grid>
    </Grid> 
</Page>
