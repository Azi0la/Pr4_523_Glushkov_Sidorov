<Page x:Class="Pr4_523_Glushkov_Sidorov.Pages.Problem2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr4_523_Glushkov_Sidorov.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Problem2"
      Background="Black">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Image Source="/Images/Problem2.jpg"/>

        <Grid Grid.Row="1" Width="400" HorizontalAlignment="Left" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Content="x" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="xTB" Grid.Column="1"/>
            <Label Content="m" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="mTB" Grid.Row="1" Grid.Column="1"/>
            <StackPanel Grid.Row="2" Grid.Column="1">
                <RadioButton Content="sh(x)" Checked="RadioButton_Checked" IsChecked="True"/>
                <RadioButton Content="x^2" Checked="RadioButton_Checked"/>
                <RadioButton Content="e^x" Checked="RadioButton_Checked"/>
            </StackPanel>
            <Button x:Name="CalculateBtn" Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" HorizontalAlignment="Center"
                    Content="Вычислить"  Click="CalculateBtn_Click"/>
            <Button x:Name="ClearBtn" Grid.Row="2" Grid.Column="2" HorizontalAlignment="Center"
                    Content="Очистить" Click="ClearBtn_Click"/>
            <Label Content="Ответ:" Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="AnsTB" Grid.Column="1" Grid.Row="3"/>
            <Button x:Name="BackBtn" Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center"
        Content="Назад"  Click="BackBtn_Click"/>
        </Grid>
        
    </Grid>
</Page>
