<Page x:Class="Pr4_523_Glushkov_Sidorov.Pages.Problem3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr4_523_Glushkov_Sidorov.Pages" xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="Problem3"
      Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.75*"/>
        </Grid.RowDefinitions>
        <Image Source="/Images/Problem3.jpg" Margin="15"/>
        <Grid Grid.Row="1" Width="400" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <Label Content="Xo" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="XoTB" Grid.Column="1"/>
            <Label Content="Xk" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1"/>
            <TextBox x:Name="XkTB" Grid.Column="1" Grid.Row="1"/>
            <Label Content="dx" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2"/>
            <TextBox x:Name="DxTB" Grid.Column="1" Grid.Row="2"/>
            <Label Content="a" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="3"/>
            <TextBox x:Name="aTB" Grid.Column="1" Grid.Row="3"/>
            <Label Content="b" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="4"/>
            <TextBox x:Name="bTB" Grid.Column="1" Grid.Row="4"/>
            <Label Content="Ответ:" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="5"/>
            <TextBox x:Name="AnsTB" Grid.Column="1" Grid.Row="5" VerticalAlignment="Top" FontSize="12" Height="80" Margin="0 10"/>
            <Button x:Name="CalculateBtn" Content="Вычислить"
                    HorizontalAlignment="Center" Grid.Column="2" Grid.RowSpan="2" Click="CalculateBtn_Click"/>
            <Button x:Name="ClearBtn" Content="Очистить"  
                    HorizontalAlignment="Center" Grid.Column="2" Grid.Row="2" Grid.RowSpan="2"   Click="ClearBtn_Click"/>
            <Button x:Name="BackBtn" Content="Назад"
                    HorizontalAlignment="Center" Grid.Column="2" Grid.Row="5" Click="BackBtn_Click"/>
        </Grid>
        <WindowsFormsHost HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1" Width="350" Height="250" Margin="20">
            <charts:Chart x:Name="Chart">
                <charts:Chart.Legends>
                    <charts:Legend>
                        
                    </charts:Legend>
                </charts:Chart.Legends>
            </charts:Chart>
        </WindowsFormsHost>

    </Grid>
    <!--Twenty men had try to take him
    Twenty men had made a slip
    Twenty one would be the ranger
    With the big iron on his hip-->
</Page>
