<Page x:Class="Pr4_523_Glushkov_Sidorov.Pages.Problem3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Pr4_523_Glushkov_Sidorov.Pages" xmlns:charts="clr-namespace:System.Windows.Forms.DataVisualization.Charting;assembly=System.Windows.Forms.DataVisualization"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Problem3"
      Background="Salmon">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1.75*"/>
        </Grid.RowDefinitions>
        <Image Source="/Images/Problem3.jpg" Margin="15"/>
        <Grid Grid.Row="1" Width="400" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <Label Content="Xo" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="XoTB" Height="30" Width="120" Grid.Column="1"/>
            <Label Content="Xk" FontSize="20"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1"/>
            <TextBox x:Name="XkTB"  Height="30" Width="120" Grid.Column="1" Grid.Row="1"/>
            <Label Content="dx" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2"/>
            <TextBox x:Name="DxTB" Height="30" Width="120" Grid.Column="1" Grid.Row="2"/>
            <Label Content="a" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="3"/>
            <TextBox x:Name="aTB" Height="30" Width="120" Grid.Column="1" Grid.Row="3"/>
            <Label Content="b" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="4"/>
            <TextBox x:Name="bTB" Height="30" Width="120" Grid.Column="1" Grid.Row="4"/>
            <Label Content="Ответ:" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="5"/>
            <TextBox x:Name="AnsTB" Height="100" Width="120" Grid.Column="1" Grid.Row="5"/>
            <Button x:Name="CalculateBtn" Height="40" Width="100" Content="Вычислить" FontSize="18"
                    HorizontalAlignment="Center" Grid.Column="2" Grid.RowSpan="2" Click="CalculateBtn_Click"/>
            <Button x:Name="ClearBtn" Height="40" Width="100" Content="Очистить" FontSize="18"  
                    HorizontalAlignment="Center" Grid.Column="2" Grid.Row="2" Grid.RowSpan="2"   Click="ClearBtn_Click"/>
            <Button x:Name="BackBtn" Height="40" Width="100" Content="Назад" FontSize="18" 
                    HorizontalAlignment="Center" Grid.Column="2" Grid.Row="5" Click="BackBtn_Click"/>
        </Grid>
        <WindowsFormsHost HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1" Width="350" Height="250" Margin="20">
            <charts:Chart x:Name="Chart">
                <charts:Chart.Legends>
                    <charts:Legend>
                        
                    </charts:Legend>
                </charts:Chart.Legends>
            </charts:Chart>
        </WindowsFormsHost>

    </Grid>
    <!--Twenty men had try to take him
    Twenty men had made a slip
    Twenty one would be the ranger
    With the big iron on his hip-->
</Page>
